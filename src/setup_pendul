clc

%% Magic numbers (replace with received numbers)
m = 3;
n = 13;

%% Process data and experiment setup (fixed, do not modify)
Ts = 500e-6; % fundamental step size

u_star = 1.2+n*0.075;
delta = 0.125;
delta_spab = 0.075;

umin = -5; umax = 5; % input saturation
ymin = -100; ymax = 100; % output saturation

g = 9.81;
% pendulum parameters
M = 0.8-n/48;
l = 1.2-m/24;
b = 0.3+m/24;
% measurement
c1 = 180/pi;
c2 = 4+n/2;

% (theta0,omega0)
rng(m+10*n)
x0_slx = [(n+3)/50,(-1)^(n+1)*m/20];

% input white noise power and sampling time
whtn_pow_in = 1e-10*(Ts*1e4)/2; 
whtn_Ts_in = Ts*2;
whtn_seed_in = 23341+m+2*n;
q_in = (umax-umin)/pow2(13); % input quantizer (DAC)

% output white noise power and sampling time
whtn_pow_out = 1e-3*Ts; 
whtn_Ts_out = Ts*2;
whtn_seed_out = 23342-m-2*n;
q_out = (ymax-ymin)/pow2(13); % output quantizer (ADC)

meas_rep = round(7+n/2); % data acquisition hardware sampling limitation

%% Input setup (can be changed/replaced/deleted)
t1=8;%%12 8
tr=0.5*2;%timpul de urcare aproximativ *2,3 datorita oscilatiilor
N=5;%la alegere%%4
p=round(tr/N/Ts)

DeltaT=p*(2^N-1)*Ts*2;%daca pun Ts/2 -> calibrare proasta , daca pun *3 se repeta astfel 3 perioade 
%%durata SPAB

[input_LUT_dSPACE,Tfin]=generate_input_signal(Ts,t1,DeltaT,N,p,u_star,delta,delta_spab);



%% Data acquisition (use t, u, y to perform system identification)
out = sim("DEAC_Lorena_pendul_R2025a.slx");

t = out.tout;
u = out.u;
y = out.y;

subplot(211)
plot(t,u)
subplot(212)
plot(t,y)
shg

%% System identification
%unele pornsc mai brusc d=si altele tangent , in functie de numere

i1=27818;
i2=59963;
i3=69777;
i4=102592;

N=13;%decimare date

t_id = t(i1:N:i2);
u_id = u(i1:N:i2);
u_id=u_id-mean(u_id);%%elimin componentele continue stationare DC
y_id = y(i1:N:i2);
y_id=y_id-mean(y_id);%%elimin componentele continue stationare DC

t_vd = t(i3:N:i4);
u_vd = u(i3:N:i4);
u_vd=u_vd-mean(u_vd);
y_vd = y(i3:N:i4);
y_vd=y_vd-mean(y_vd);

figure;
