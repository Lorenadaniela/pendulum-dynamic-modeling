% Polii modelului ARMAX in plan z
poli_armax_plan_z = pole(model_armax)

% Perioada de esantionare
Ts_armax = model_armax.Ts;

% Modul si argument
r_armax = abs(poli_armax_plan_z);
theta_armax = angle(poli_armax_plan_z);

% Conversie manuala z -> s
poli_armax_plan_s = (log(r_armax) + 1j*theta_armax) / Ts_armax

% Conversie automata discret -> continuu
model_armax_continu = d2c(model_armax,'tustin');

% Zerouri si poli in plan s
z_armax_plan_s = tzero(model_armax_continu)
p_armax_plan_s = pole(model_armax_continu)

[num, den] = tfdata(model_armax,'v')


